# OpenAI API 配置
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4

# 飞书测试企业应用配置
FEISHU_APP_ID=your-feishu-app-id
FEISHU_APP_SECRET=your-feishu-app-secret
# 飞书事件订阅配置（在飞书开发者后台获取）
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
# 服务端口
PORT=3000

# Playwright 配置
PLAYWRIGHT_HEADLESS=false
PLAYWRIGHT_TIMEOUT=30000
PLAYWRIGHT_SLOW_MO=100
PLAYWRIGHT_BROWSER=chrome
PLAYWRIGHT_VIEWPORT_WIDTH=1728
PLAYWRIGHT_VIEWPORT_HEIGHT=883

# 消息通知策略配置 (true=发送, false=静默)
# 任务创建确认 - 默认静默，避免每次创建任务都发消息
NOTIFY_TASK_CREATED=false
# 任务执行结果 - 默认发送，关键时机通知
NOTIFY_TASK_EXECUTED=true
# 风险识别预警 - 默认发送，关键时机通知
NOTIFY_RISK_DETECTED=true
# 进度状态变更 - 默认静默
NOTIFY_PROGRESS_UPDATE=false
# 用户主动查询回复 - 默认发送
NOTIFY_USER_QUERY=true
